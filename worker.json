{
  "tool": "opencode",
  "model": "opencode/deepseek-v4-flash-free",
  "max_workers": 5,
  "port_base": 4091,
  "timeout": 300,
  "available_models": [
    "opencode/deepseek-v4-flash-free",
    "opencode/mimo-v2.5-free",
    "opencode/gpt-5.5",
    "opencode/claude-opus-4-8"
  ],
  "permission": {
    "bash": "allow",
    "read": "allow",
    "edit": "allow",
    "write": "allow",
    "glob": "allow",
    "grep": "allow",
    "task": "allow",
    "webfetch": "deny",
    "websearch": "deny",
    "question": "deny",
    "external_directory": {
      "/tmp/*": "deny",
      "__PROJECT_DIR__/*": "allow",
      "/root/*": "allow",
      "/opt/*": "allow"
    }
  },
  "description": "Worker agent - bị Manager giao việc, chạy dưới dạng opencode serve",
  "mode": "primary",
  "prompt": "Bạn là Worker. Bạn nhận lệnh từ Manager qua HTTP API và THỰC THI.\nKhông tự đặt mục tiêu, không hỏi người dùng.\nTất cả quyền đã được cấp sẵn — cứ làm."
}
