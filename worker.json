{
  "model": "deepapi/deepseek-v4-pro",
  "max_workers": 5,
  "port_base": 4091,
  "timeout": 300,
  "available_models": [
    "deepapi/deepseek-chat",
    "deepapi/deepseek-v4-flash",
    "deepapi/deepseek-v4-pro"
  ],
  "permission": {
    "bash": "allow",
    "read": "allow",
    "edit": "allow",
    "write": "allow",
    "glob": "allow",
    "grep": "allow",
    "task": "allow",
    "webfetch": "deny",
    "websearch": "deny",
    "question": "deny",
    "external_directory": {
      "/tmp/*": "deny",
      "__PROJECT_DIR__/*": "allow",
      "/root/*": "allow",
      "/opt/*": "allow"
    }
  }
}
