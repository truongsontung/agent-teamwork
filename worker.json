{
  "tool": "opencode",
  "model": "opencode/deepseek-v4-flash-free",
  "max_workers": 5,
  "available_models": [
    "opencode/deepseek-v4-flash-free",
    "opencode/mimo-v2.5-free",
    "opencode/gpt-5.5",
    "opencode/claude-opus-4-8"
  ],
  "permission": {
    "bash": "allow",
    "read": "allow",
    "edit": "allow",
    "write": "allow",
    "glob": "allow",
    "grep": "allow",
    "task": "allow",
    "webfetch": "deny",
    "websearch": "deny",
    "question": "deny",
    "external_directory": {
      "/tmp/*": "deny",
      "__PROJECT_DIR__/*": "allow",
      "/root/*": "allow",
      "/opt/*": "allow"
    }
  },
  "description": "Worker agent - bị Manager giao việc, quyền bị giới hạn",
  "mode": "primary",
  "prompt": "Bạn là Worker. Bạn nhận lệnh từ Manager qua tmux và THỰC THI.\nKhông tự đặt mục tiêu, không hỏi người dùng.\nCứ làm — nếu gặp prompt quyền, Manager sẽ xử lý."
}
